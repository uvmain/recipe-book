{
  "name": "recipebook",
  "version": "1.0.0",
  "description": "Self Hosted Recipe recipebook",
  "main": "index.js",
  "workspaces": [
    "./frontend"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uvmain/recipe-book.git"
  },
  "scripts": {
    "setup": "go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest && go install golang.org/x/vuln/cmd/govulncheck@latest && go mod download",
    "clean": "rimraf -v -I recipebook frontend/dist",
    "clean:build": "rimraf -v -I recipebook frontend/dist",
    "clean:full": "rimraf -v -I recipebook data frontend/dist frontend/node_modules node_modules",
    "dev:backend": "go run .",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev": "concurrently npm:caddy npm:dev:backend npm:dev:frontend",
    "build:backend": "cross-env CGO_ENABLED=0 go build -ldflags=\"-s -w\" -o recipebook && cpy recipebook . --rename=recipebook.exe",
    "build:frontend": "npm run build --workspace frontend",
    "build": "npm run build:frontend && npm run build:backend",
    "preview": "concurrently npm:caddy:preview npm:preview:go",
    "preview:go": "recipebook",
    "caddy": "caddy run --config Caddyfile",
    "caddy:preview": "caddy run --config Caddyfile.preview",
    "cspell": "cspell \"**/*.{go,ts,js,vue}\"",
    "audit": "npm audit && govulncheck ./...",
    "lint:backend": "golangci-lint run",
    "lint:frontend": "npm run lint --workspace frontend",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:fix": "npm run lint:fix --workspace frontend"
  },
  "devDependencies": {
    "caddy-baron": "^4.0.0",
    "concurrently": "^9.2.1",
    "cpy-cli": "^7.0.0",
    "cross-env": "^10.1.0",
    "cspell": "^9.6.4",
    "rimraf": "^6.1.3"
  }
}
